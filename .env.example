# Codex Autonomous Runner Configuration
# Copy this to .env and fill in your values

# Required: OpenAI/ChatGPT credentials
CODEX_EMAIL=your-email@example.com
CODEX_PASSWORD=your-password

# Optional: TOTP secret for automatic MFA (base32 key from authenticator setup)
# CODEX_TOTP_SECRET=YOUR_TOTP_SECRET_HERE

# Optional: Codex base URL (default: https://chatgpt.com/codex)
# CODEX_URL=https://chatgpt.com/codex

# Optional: Environment to select in Codex
# CODEX_ENV=default

# Optional: Run headless (default: true)
# CODEX_HEADLESS=true

# Optional: Task timeout in seconds (default: 900)
# CODEX_TASK_TIMEOUT=900

# Optional: Login timeout in seconds (default: 120)
# CODEX_LOGIN_TIMEOUT=120

# Optional: Max retries per ticket (default: 2)
# CODEX_MAX_RETRIES=2

# Optional: Request PR after each ticket (default: true)
# CODEX_REQUEST_PR=true

# Optional: Poll interval in seconds (default: 3)
# CODEX_POLL_INTERVAL=3

# Optional: Screenshot directory (default: screenshots)
# CODEX_SCREENSHOT_DIR=screenshots

# Optional: Session storage file (default: .playwright_storage_state.json)
# CODEX_STORAGE_STATE=.playwright_storage_state.json
